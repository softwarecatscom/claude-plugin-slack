#!/usr/bin/env bash
# Shell wrapper for slack-heartbeat.py
# Runs the Python heartbeat script via uv for dependency management.
#
# Usage: slack-heartbeat [CHANNEL_ID]
#   CHANNEL_ID — channel containing the pinned status thread (default: from slack.conf)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

exec uv run "${SCRIPT_DIR}/slack-heartbeat.py" "$@"
