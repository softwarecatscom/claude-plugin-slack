#!/usr/bin/env bash
# Send or edit a Slack message with automatic @name and #channel resolution.
# Resolves @DisplayName to <@USERID> and #channel to the channel ID using the resolve cache.
#
# Usage: slack-send [--thread PARENT_TS] [--broadcast] [--update TS] CHANNEL TEXT
#   CHANNEL     — channel name (without #) or channel ID
#   TEXT        — message text, may contain @DisplayName references
#   --thread TS — reply in a thread (TS is the parent message timestamp)
#   --broadcast — make thread reply visible in channel (requires --thread)
#   --update TS — edit an existing message (TS is the message timestamp to edit)
#
# Examples:
#   slack-send agents "@Z490 Hey, deploy is done"
#   slack-send --thread 1773378707.594569 agents "Replying in thread"
#   slack-send --thread 1773378707.594569 --broadcast agents "Thread reply visible in channel"
#   slack-send --update 1773378707.594569 agents "Edited message text"

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Parse all args: extract flags from any position, collect positionals
THREAD_TS=""
REPLY_BROADCAST=false
UPDATE_TS=""
POSITIONALS=()
while [ $# -gt 0 ]; do
  case "${1}" in
    --thread) THREAD_TS="${2}"; shift 2 ;;
    --broadcast) REPLY_BROADCAST=true; shift ;;
    --update) UPDATE_TS="${2}"; shift 2 ;;
    *) POSITIONALS+=("${1}"); shift ;;
  esac
done

CHANNEL="${POSITIONALS[0]:-}"
TEXT="${POSITIONALS[1]:-}"

if [ -z "${CHANNEL}" ] || [ -z "${TEXT}" ]; then
  echo "Usage: slack-send [--thread PARENT_TS] [--broadcast] [--update TS] CHANNEL TEXT" >&2
  exit 1
fi

# Load token
SLACK_TOKEN=$(cat "$(dirname "$(which slack)")/.slack" 2>/dev/null)
if [ -z "${SLACK_TOKEN}" ]; then
  echo "ERROR: No Slack token found. Run /scc-slack:setup first." >&2
  exit 1
fi

# Resolve channel name to ID if it doesn't look like a channel ID
CHANNEL_ID="${CHANNEL}"
if [[ ! "${CHANNEL}" =~ ^C[A-Z0-9]+$ ]]; then
  RESOLVED=$("${SCRIPT_DIR}/slack-resolve" --channel "${CHANNEL}" 2>/dev/null | head -1 | cut -d= -f1)
  if [ -n "${RESOLVED}" ] && [ "${RESOLVED}" != "UNKNOWN" ]; then
    CHANNEL_ID="${RESOLVED}"
  else
    echo "ERROR: Could not resolve channel '${CHANNEL}'" >&2
    exit 1
  fi
fi

# Resolve broadcast mentions first (@here, @channel, @everyone → Slack encoding)
RESOLVED_TEXT="${TEXT}"
RESOLVED_TEXT="${RESOLVED_TEXT//@here/<!here>}"
RESOLVED_TEXT="${RESOLVED_TEXT//@channel/<!channel>}"
RESOLVED_TEXT="${RESOLVED_TEXT//@everyone/<!everyone>}"

# Resolve @mentions in the text
# Find all @Name patterns (word after @, may include underscores/digits)
while IFS= read -r name; do
  [ -z "${name}" ] && continue
  # Look up the name to get user ID
  MATCH=$("${SCRIPT_DIR}/slack-resolve" --name "${name}" 2>/dev/null | head -1)
  if [ -n "${MATCH}" ] && [[ "${MATCH}" != UNKNOWN=* ]]; then
    UID_RESOLVED="${MATCH%%=*}"
    # Replace @Name with <@USERID>
    RESOLVED_TEXT="${RESOLVED_TEXT//@${name}/<@${UID_RESOLVED}>}"
  fi
done < <(echo "${TEXT}" | grep -oE '@[A-Za-z][A-Za-z0-9_]+' | sed 's/^@//' | sort -u | awk '{print length, $0}' | sort -rn | cut -d' ' -f2-)

# Build JSON payload
JQ_ARGS=(--arg channel "${CHANNEL_ID}" --arg text "${RESOLVED_TEXT}")
JQ_EXPR='{channel: $channel, text: $text}'

if [ -n "${UPDATE_TS}" ]; then
  # Editing an existing message via chat.update
  JQ_ARGS+=(--arg ts "${UPDATE_TS}")
  JQ_EXPR='{channel: $channel, text: $text, ts: $ts}'
  API_ENDPOINT="https://slack.com/api/chat.update"
elif [ -n "${THREAD_TS}" ]; then
  JQ_ARGS+=(--arg thread_ts "${THREAD_TS}")
  if [ "${REPLY_BROADCAST}" = true ]; then
    JQ_EXPR='{channel: $channel, text: $text, thread_ts: $thread_ts, reply_broadcast: true}'
  else
    JQ_EXPR='{channel: $channel, text: $text, thread_ts: $thread_ts}'
  fi
  API_ENDPOINT="https://slack.com/api/chat.postMessage"
else
  API_ENDPOINT="https://slack.com/api/chat.postMessage"
fi

# Send via API
RESPONSE=$(curl -s -X POST "${API_ENDPOINT}" \
  -H "Authorization: Bearer ${SLACK_TOKEN}" \
  -H "Content-type: application/json; charset=utf-8" \
  -d "$(jq -n "${JQ_ARGS[@]}" "${JQ_EXPR}")")

if [ "$(echo "${RESPONSE}" | jq -r '.ok')" = "true" ]; then
  # chat.update returns .ts directly; chat.postMessage returns .message.ts
  echo "${RESPONSE}" | jq '{ok: .ok, ts: (.message.ts // .ts), channel: .channel}'
else
  echo "ERROR: $(echo "${RESPONSE}" | jq -r '.error')" >&2
  echo "${RESPONSE}" | jq '.' >&2
  exit 1
fi
