#!/usr/bin/env bash
# Shim for slack-cli: loads token, finds latest vendored copy, delegates.

shimdir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# 1. Load token from .slack next to this shim
if [ -r "${shimdir}/.slack" ] && [ -f "${shimdir}/.slack" ]; then
  SLACK_CLI_TOKEN=$(sed -n '1p' < "${shimdir}/.slack")
  export SLACK_CLI_TOKEN
fi

# 2. Find latest vendored slack-cli from plugin cache
SLACK_CLI=$(find ~/.claude/plugins/cache -path "*/scc-slack/*/scripts/slack" 2>/dev/null | sort -V | tail -1)

if [ -z "${SLACK_CLI}" ]; then
  echo '{"ok": false, "error": "no_vendored_slack_cli_found"}' >&2
  exit 1
fi

# 3. Intercept 'init' to write token next to shim, not next to vendored script
if [ "${1}" = "init" ]; then
  # Extract --token value from args
  _token=""
  shift
  while [ $# -gt 0 ]; do
    case "${1}" in
      --token|-tk) _token="${2}"; shift 2 ;;
      *) shift ;;
    esac
  done

  if [ -z "${_token}" ]; then
    read -r -e -p 'Enter Slack API token: ' _token
  fi

  if [ -n "${_token}" ]; then
    echo "${_token}" > "${shimdir}/.slack"
    echo '{"ok": true}'
  else
    echo '{"ok": false, "error": "no_token"}' >&2
    exit 1
  fi
  exit 0
fi

# 4. Delegate to vendored slack-cli
exec bash "${SLACK_CLI}" "$@"
