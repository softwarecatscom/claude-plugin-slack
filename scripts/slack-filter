#!/usr/bin/env bash
# Filter Slack messages for ones that mention a specific user.
# Reads raw conversations.history or conversations.replies JSON from stdin,
# outputs only actionable messages.
#
# Usage: echo "$JSON" | slack-filter [--thread-participant]
#
# Loads identity from ~/.claude/slack-cache/identity (run slack-identity first).
# A message is actionable if it:
#   - Contains <@YOUR_USER_ID>
#   - Contains @username, @display_name, or @real_name (case-insensitive, requires @ prefix)
#   - Contains <!here>, <!channel>, or <!everyone>
#   - Is NOT from your own user ID
#   - (with --thread-participant) Is any message from another user in a thread
#     the agent participates in
#
# Output: JSON array of matching messages with metadata:
#   [{"ts": "...", "user": "...", "text": "...", "match_type": "direct|broadcast|name|thread_participant"}]

set -euo pipefail

# Parse flags
THREAD_PARTICIPANT=false
while [ $# -gt 0 ]; do
  case "${1}" in
    --thread-participant) THREAD_PARTICIPANT=true; shift ;;
    *) shift ;;
  esac
done

CACHE_DIR="${HOME}/.claude/slack-cache"
IDENTITY_FILE="${CACHE_DIR}/identity"

if [ ! -f "${IDENTITY_FILE}" ]; then
  echo "ERROR: No identity cached. Run slack-identity first." >&2
  exit 1
fi

# Load identity (source is safer than eval — no command execution)
# shellcheck disable=SC1090
source "${IDENTITY_FILE}"

# Read JSON from stdin
INPUT=$(cat)

# Detect empty input (broken pipeline — caller likely failed)
if [ -z "${INPUT}" ]; then
  echo "ERROR: No input received. Check that the caller provides valid JSON on stdin." >&2
  echo '[]'
  exit 0
fi

# Check API response is ok
if [ "$(echo "${INPUT}" | jq -r '.ok')" != "true" ]; then
  ERROR_MSG=$(echo "${INPUT}" | jq -r '.error // "unknown"')
  HINT_MSG=$(echo "${INPUT}" | jq -r '.hint // empty')
  echo "ERROR: API response not ok: ${ERROR_MSG}${HINT_MSG:+ ($HINT_MSG)}" >&2
  echo '[]'
  exit 0
fi

# Filter messages using jq
# Pass identity values as jq args for safe interpolation
echo "${INPUT}" | jq --arg uid "${USER_ID}" \
                     --arg uname "${USERNAME}" \
                     --arg dname "${DISPLAY_NAME}" \
                     --arg rname "${REAL_NAME}" \
                     --argjson tp "${THREAD_PARTICIPANT}" '
[.messages[]
 | select(.user != $uid)
 | select(.subtype == null or .subtype == "bot_message" or .subtype == "thread_broadcast")
 | . as $msg
 | (
     # Check for direct mention <@USER_ID>
     if (.text | test("<@" + $uid + ">")) then "direct"
     # Check for broadcast mentions
     elif (.text | test("<!here>|<!channel>|<!everyone>|(^|\\s)@here(\\s|$)|(^|\\s)@channel(\\s|$)|(^|\\s)@everyone(\\s|$)")) then "broadcast"
     # Check for @name mentions (case-insensitive, require @ prefix to avoid false positives)
     elif ($uname != "" and (.text | ascii_downcase | test("@" + ($uname | ascii_downcase)))) then "name"
     elif ($dname != "" and (.text | ascii_downcase | test("@" + ($dname | ascii_downcase)))) then "name"
     elif ($rname != "" and $rname != $dname and (.text | ascii_downcase | test("@" + ($rname | ascii_downcase)))) then "name"
     # Thread participant: any message in a thread we participate in
     elif $tp then "thread_participant"
     else null
     end
   ) as $match_type
 | select($match_type != null)
 | {ts: .ts, user: .user, text: .text, match_type: $match_type, bot_id: (.bot_id // null), thread_ts: (.thread_ts // null)}
] | reverse'
