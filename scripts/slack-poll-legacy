#!/usr/bin/env bash
# Poll configured Slack channels for new messages mentioning this bot.
# Reads AUTONOMOUS_CHANNELS from ~/.claude/slack.conf, resolves channel names
# to IDs, fetches history, filters for mentions, and scans threads.
#
# Usage: slack-poll
#
# Output: Per-channel JSON blocks. Each channel produces either:
#   - A JSON array of matching messages (may be empty [])
#   - Prefixed with a comment line: # channel=CHANNEL_NAME id=CHANNEL_ID
#
# Exit code: 0 always (errors are reported in output, not via exit code)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CONFIG_FILE="${HOME}/.claude/slack.conf"

# Load config
if [ ! -f "${CONFIG_FILE}" ]; then
  echo "ERROR: No config found at ${CONFIG_FILE}. Run /scc-slack:setup first." >&2
  echo '{"ok":false,"error":"no_config","hint":"Run /scc-slack:setup first"}'
  exit 1
fi

# shellcheck disable=SC1090
source "${CONFIG_FILE}"

# Proxy support: use proxy if configured, fall back to direct Slack
SLACK_API_BASE="${SLACK_PROXY_URL:-https://slack.com}"
# shellcheck disable=SC1091
source "${SCRIPT_DIR}/slack-common"

if [ -z "${AUTONOMOUS_CHANNELS:-}" ]; then
  echo "ERROR: AUTONOMOUS_CHANNELS not set in ${CONFIG_FILE}." >&2
  echo '{"ok":false,"error":"no_channels","hint":"Set AUTONOMOUS_CHANNELS in ~/.claude/slack.conf"}'
  exit 1
fi

# Load token
SLACK_TOKEN=$(cat "$(dirname "$(which slack)")/.slack" 2>/dev/null)
if [ -z "${SLACK_TOKEN}" ]; then
  echo "ERROR: No Slack token found. Run /scc-slack:setup first." >&2
  echo '{"ok":false,"error":"no_token","hint":"Run /scc-slack:setup first"}'
  exit 1
fi

# Ensure identity is cached (needed by slack-filter)
if [ ! -f "${HOME}/.claude/slack-cache/identity" ]; then
  "${SCRIPT_DIR}/slack-identity" >/dev/null 2>&1 || true
fi

# Poll each channel
IFS=',' read -ra CHANNELS <<< "${AUTONOMOUS_CHANNELS}"
for CHANNEL_NAME in "${CHANNELS[@]}"; do
  CHANNEL_NAME=$(echo "${CHANNEL_NAME}" | xargs)  # trim whitespace
  [ -z "${CHANNEL_NAME}" ] && continue

  # Resolve channel name to ID
  CHANNEL_ID="${CHANNEL_NAME}"
  if [[ ! "${CHANNEL_NAME}" =~ ^C[A-Z0-9]+$ ]]; then
    RESOLVED=$("${SCRIPT_DIR}/slack-resolve" --channel "${CHANNEL_NAME}" 2>/dev/null | head -1 | cut -d= -f1)
    if [ -n "${RESOLVED}" ] && [ "${RESOLVED}" != "UNKNOWN" ]; then
      CHANNEL_ID="${RESOLVED}"
    else
      echo "# channel=${CHANNEL_NAME} id=UNKNOWN"
      echo '[]'
      echo "ERROR: Could not resolve channel '${CHANNEL_NAME}'" >&2
      continue
    fi
  fi

  echo "# channel=${CHANNEL_NAME} id=${CHANNEL_ID}"

  # Save cursor BEFORE fetching (needed for thread latest_reply comparison)
  CURSOR_FILE="${HOME}/.claude/slack-cursors.conf"
  OLD_CURSOR=$(grep "^${CHANNEL_ID}=" "${CURSOR_FILE}" 2>/dev/null | cut -d= -f2 || true)

  # Fetch channel history (cursor advances manually after thread scanning)
  if [ -n "${OLD_CURSOR}" ]; then
    HISTORY=$(slack_curl -s -H "Authorization: Bearer ${SLACK_TOKEN}" \
      "${SLACK_API_BASE}/api/conversations.history?channel=${CHANNEL_ID}&oldest=${OLD_CURSOR}&limit=20") || true
  else
    HISTORY=$(slack_curl -s -H "Authorization: Bearer ${SLACK_TOKEN}" \
      "${SLACK_API_BASE}/api/conversations.history?channel=${CHANNEL_ID}&limit=10") || true
  fi

  # Filter for mentions in channel-level messages
  echo "${HISTORY}" | "${SCRIPT_DIR}/slack-filter" || echo '[]'

  # Thread scanning: check threads we participate in for new activity
  IDENTITY_FILE="${HOME}/.claude/slack-cache/identity"
  if [ -f "${IDENTITY_FILE}" ]; then
    # shellcheck disable=SC1090
    source "${IDENTITY_FILE}"

    # Fetch recent history (last 50 messages) WITHOUT cursor for thread scanning.
    # The cursor-filtered HISTORY only has new messages — parents posted in earlier
    # polls won't be there. This wider fetch catches older parents with new replies.
    THREAD_HISTORY=$(slack_curl -s -H "Authorization: Bearer ${SLACK_TOKEN}" \
      "${SLACK_API_BASE}/api/conversations.history?channel=${CHANNEL_ID}&limit=50")

    # Use thread cursor (separate from channel cursor) for latest_reply comparison
    THREAD_CURSOR_FILE="${HOME}/.claude/slack-thread-cursors.conf"
    OLD_THREAD_CURSOR=$(grep "^${CHANNEL_ID}=" "${THREAD_CURSOR_FILE}" 2>/dev/null | cut -d= -f2 || true)
    # Use whichever cursor is more relevant: thread cursor if set, else channel cursor
    EFFECTIVE_THREAD_CURSOR="${OLD_THREAD_CURSOR:-${OLD_CURSOR}}"

    # Find parent messages where we participate and have new thread activity
    # Participation = we posted the parent OR we're in reply_users
    # Cap at 5 threads, sorted by latest_reply (newest first)
    THREAD_PARENTS=$(echo "${THREAD_HISTORY}" | jq -r --arg uid "${USER_ID}" --arg cursor "${EFFECTIVE_THREAD_CURSOR}" '
      [.messages // [] | .[]
       | select(.reply_count > 0
                and (.user == $uid or (.reply_users | index($uid)))
                and (if $cursor != "" then .latest_reply > $cursor else true end))
       | {ts: .ts, latest_reply: .latest_reply}]
      | sort_by(.latest_reply) | reverse | .[0:5] | .[].ts' 2>/dev/null) || true

    # Fetch and filter each participating thread
    for PARENT_TS in ${THREAD_PARENTS}; do
      [ -z "${PARENT_TS}" ] && continue

      echo "# thread=${PARENT_TS} channel=${CHANNEL_ID}"
      REPLIES=$(slack_curl -s -H "Authorization: Bearer ${SLACK_TOKEN}" \
        "${SLACK_API_BASE}/api/conversations.replies?channel=${CHANNEL_ID}&ts=${PARENT_TS}&oldest=${EFFECTIVE_THREAD_CURSOR:-0}")

      # Strip thread_broadcast replies (already in channel output) then filter
      echo "${REPLIES}" | jq '{ok: .ok, messages: [.messages[] | select(.subtype != "thread_broadcast")]}' 2>/dev/null \
        | "${SCRIPT_DIR}/slack-filter" --thread-participant || echo '[]'
    done

    # AGT-40: Scan threads we DON'T participate in for @mentions
    # Find threads with new activity where we're NOT in reply_users
    # Cap at 5 threads to bound API calls
    MENTION_PARENTS=$(echo "${THREAD_HISTORY}" | jq -r --arg uid "${USER_ID}" --arg cursor "${EFFECTIVE_THREAD_CURSOR}" '
      [.messages // [] | .[]
       | select(.reply_count > 0
                and (.user != $uid)
                and ((.reply_users | index($uid)) | not)
                and (if $cursor != "" then .latest_reply > $cursor else true end))
       | {ts: .ts, latest_reply: .latest_reply}]
      | sort_by(.latest_reply) | reverse | .[0:5] | .[].ts' 2>/dev/null) || true

    # Fetch replies and filter for direct @mentions only
    for PARENT_TS in ${MENTION_PARENTS}; do
      [ -z "${PARENT_TS}" ] && continue

      REPLIES=$(slack_curl -s -H "Authorization: Bearer ${SLACK_TOKEN}" \
        "${SLACK_API_BASE}/api/conversations.replies?channel=${CHANNEL_ID}&ts=${PARENT_TS}&oldest=${EFFECTIVE_THREAD_CURSOR:-0}")

      # Check if any reply mentions us — only output if there are matches
      MENTION_MATCHES=$(echo "${REPLIES}" | jq --arg uid "${USER_ID}" '
        {ok: .ok, messages: [.messages[] | select(.subtype != "thread_broadcast" and (.text | contains("<@" + $uid + ">"))]}
        | select(.messages | length > 0)' 2>/dev/null) || true

      if [ -n "${MENTION_MATCHES}" ]; then
        echo "# thread=${PARENT_TS} channel=${CHANNEL_ID}"
        echo "${MENTION_MATCHES}" | "${SCRIPT_DIR}/slack-filter" || echo '[]'
      fi
    done
  fi

  # Advance channel cursor to newest fetched channel message
  NEWEST_TS=$(echo "${HISTORY}" | jq -r '.messages[0].ts // empty' 2>/dev/null)
  if [ -n "${NEWEST_TS}" ]; then
    TMPFILE=$(mktemp /tmp/slack-cursors.XXXXXX)
    grep -v "^${CHANNEL_ID}=" "${CURSOR_FILE}" > "${TMPFILE}" 2>/dev/null || true
    echo "${CHANNEL_ID}=${NEWEST_TS}" >> "${TMPFILE}"
    mv "${TMPFILE}" "${CURSOR_FILE}"
  fi

  # Advance thread cursor to newest thread reply we processed
  # Separate from channel cursor to avoid skipping channel messages
  THREAD_CURSOR_FILE="${HOME}/.claude/slack-thread-cursors.conf"
  NEWEST_THREAD_TS=""
  for PARENT_TS in ${THREAD_PARENTS:-}; do
    LATEST=$(echo "${THREAD_HISTORY}" | jq -r --arg ts "${PARENT_TS}" '
      .messages // [] | .[] | select(.ts == $ts) | .latest_reply // empty' 2>/dev/null)
    if [ -n "${LATEST}" ] && [[ "${LATEST}" > "${NEWEST_THREAD_TS:-}" ]]; then
      NEWEST_THREAD_TS="${LATEST}"
    fi
  done
  if [ -n "${NEWEST_THREAD_TS}" ]; then
    TMPFILE=$(mktemp /tmp/slack-cursors.XXXXXX)
    grep -v "^${CHANNEL_ID}=" "${THREAD_CURSOR_FILE}" > "${TMPFILE}" 2>/dev/null || true
    echo "${CHANNEL_ID}=${NEWEST_THREAD_TS}" >> "${TMPFILE}"
    mv "${TMPFILE}" "${THREAD_CURSOR_FILE}"
  fi
done

# Heartbeat: update agent status after polling
"${SCRIPT_DIR}/slack-heartbeat" 2>/dev/null || true
