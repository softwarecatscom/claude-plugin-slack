#!/usr/bin/env bash
# Shell wrapper for slack-poll.py
# Long-running poller that polls Slack and only exits when actionable messages arrive.
# Designed to run via Bash(run_in_background: true) for zero-token polling.
#
# Usage:
#   slack-poll              — run until actionable messages found
#   slack-poll once         — run a single cycle (for testing)
#   slack-poll stop         — stop any running poller
#   slack-poll status       — check if poller is running

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

exec uv run --no-project "${SCRIPT_DIR}/slack-poll.py" "$@"
