#!/usr/bin/env bash
# Fetch messages from a Slack channel since the stored cursor.
# Automatically reads the cursor, outputs raw JSON from conversations.history,
# and auto-advances the cursor to the newest fetched message timestamp.
#
# Usage: slack-fetch CHANNEL_ID [--limit N] [--no-advance]
# Output: Raw JSON response from conversations.history
#
# If no cursor exists, fetches the last 10 messages.
# The cursor is auto-advanced after a successful fetch so that agents
# don't need to (and can't incorrectly) update it manually.

set -euo pipefail

CHANNEL_ID="${1:-}"
if [ -z "${CHANNEL_ID}" ]; then
  echo "Usage: slack-fetch CHANNEL_ID [--limit N]" >&2
  echo '{"ok":false,"error":"missing_channel_id","hint":"Usage: slack-fetch CHANNEL_ID [--limit N]"}'
  exit 1
fi
shift

LIMIT=20
AUTO_ADVANCE=true
while [ $# -gt 0 ]; do
  case "${1}" in
    --limit) LIMIT="${2}"; shift 2 ;;
    --no-advance) AUTO_ADVANCE=false; shift ;;
    *) shift ;;
  esac
done

# Load token
SLACK_TOKEN=$(cat "$(dirname "$(which slack)")/.slack" 2>/dev/null)
if [ -z "${SLACK_TOKEN}" ]; then
  echo "ERROR: No Slack token found. Run /scc-slack:setup first." >&2
  echo '{"ok":false,"error":"no_token","hint":"Run /scc-slack:setup first"}'
  exit 1
fi

# Cursor file
CURSOR_FILE="${HOME}/.claude/slack-cursors.conf"
CURSOR=$(grep "^${CHANNEL_ID}=" "${CURSOR_FILE}" 2>/dev/null | cut -d= -f2 || true)

if [ -n "${CURSOR}" ]; then
  RESPONSE=$(curl -s -H "Authorization: Bearer ${SLACK_TOKEN}" \
    "https://slack.com/api/conversations.history?channel=${CHANNEL_ID}&oldest=${CURSOR}&limit=${LIMIT}")
else
  RESPONSE=$(curl -s -H "Authorization: Bearer ${SLACK_TOKEN}" \
    "https://slack.com/api/conversations.history?channel=${CHANNEL_ID}&limit=10")
fi

# Auto-advance cursor to newest fetched message timestamp
if [ "${AUTO_ADVANCE}" = true ]; then
  NEWEST_TS=$(echo "${RESPONSE}" | jq -r '.messages[0].ts // empty' 2>/dev/null)
  if [ -n "${NEWEST_TS}" ]; then
    grep -v "^${CHANNEL_ID}=" "${CURSOR_FILE}" > /tmp/slack-cursors.tmp 2>/dev/null || true
    echo "${CHANNEL_ID}=${NEWEST_TS}" >> /tmp/slack-cursors.tmp
    mv /tmp/slack-cursors.tmp "${CURSOR_FILE}"
  fi
fi

echo "${RESPONSE}"
