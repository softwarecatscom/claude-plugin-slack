#!/usr/bin/env bash
# Fetch messages from a Slack channel since the stored cursor.
# Automatically reads the cursor, outputs raw JSON from conversations.history,
# and auto-advances the cursor to the newest fetched message timestamp.
#
# Usage: slack-fetch CHANNEL_ID [--limit N] [--no-advance] [--pins]
# Output: Raw JSON response from conversations.history (or pins.list with --pins)
#
# Options:
#   --limit N      — max messages to fetch (default 20)
#   --no-advance   — don't auto-advance the cursor after fetch
#   --pins         — fetch pinned messages instead of history (no cursor used)
#
# If no cursor exists, fetches the last 10 messages.
# The cursor is auto-advanced after a successful fetch so that agents
# don't need to (and can't incorrectly) update it manually.

set -euo pipefail

# Parse all args: extract flags from any position, collect positionals
LIMIT=20
AUTO_ADVANCE=true
FETCH_PINS=false
POSITIONALS=()
while [ $# -gt 0 ]; do
  case "${1}" in
    --limit) LIMIT="${2}"; shift 2 ;;
    --no-advance) AUTO_ADVANCE=false; shift ;;
    --pins) FETCH_PINS=true; shift ;;
    *) POSITIONALS+=("${1}"); shift ;;
  esac
done

CHANNEL_ID="${POSITIONALS[0]:-}"
if [ -z "${CHANNEL_ID}" ]; then
  echo "Usage: slack-fetch CHANNEL_ID [--limit N] [--no-advance] [--pins]" >&2
  echo '{"ok":false,"error":"missing_channel_id","hint":"Usage: slack-fetch CHANNEL_ID [--limit N] [--no-advance] [--pins]"}'
  exit 1
fi

# Load token
SLACK_TOKEN=$(cat "$(dirname "$(which slack)")/.slack" 2>/dev/null)
if [ -z "${SLACK_TOKEN}" ]; then
  echo "ERROR: No Slack token found. Run /scc-slack:setup first." >&2
  echo '{"ok":false,"error":"no_token","hint":"Run /scc-slack:setup first"}'
  exit 1
fi

# Pins mode: fetch pinned messages and exit (no cursor involved)
if [ "${FETCH_PINS}" = true ]; then
  RESPONSE=$(curl -s -H "Authorization: Bearer ${SLACK_TOKEN}" \
    "https://slack.com/api/pins.list?channel=${CHANNEL_ID}")
  # Normalize output: extract messages from pins items for consistency
  echo "${RESPONSE}" | jq '{ok: .ok, messages: [.items // [] | .[] | .message]}'
  exit 0
fi

# Cursor file
CURSOR_FILE="${HOME}/.claude/slack-cursors.conf"
CURSOR=$(grep "^${CHANNEL_ID}=" "${CURSOR_FILE}" 2>/dev/null | cut -d= -f2 || true)

if [ -n "${CURSOR}" ]; then
  RESPONSE=$(curl -s -H "Authorization: Bearer ${SLACK_TOKEN}" \
    "https://slack.com/api/conversations.history?channel=${CHANNEL_ID}&oldest=${CURSOR}&limit=${LIMIT}")
else
  RESPONSE=$(curl -s -H "Authorization: Bearer ${SLACK_TOKEN}" \
    "https://slack.com/api/conversations.history?channel=${CHANNEL_ID}&limit=10")
fi

# Auto-advance cursor to newest fetched message timestamp
if [ "${AUTO_ADVANCE}" = true ]; then
  NEWEST_TS=$(echo "${RESPONSE}" | jq -r '.messages[0].ts // empty' 2>/dev/null)
  if [ -n "${NEWEST_TS}" ]; then
    TMPFILE=$(mktemp /tmp/slack-cursors.XXXXXX)
    grep -v "^${CHANNEL_ID}=" "${CURSOR_FILE}" > "${TMPFILE}" 2>/dev/null || true
    echo "${CHANNEL_ID}=${NEWEST_TS}" >> "${TMPFILE}"
    mv "${TMPFILE}" "${CURSOR_FILE}"
  fi
fi

echo "${RESPONSE}"
